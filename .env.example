# Copy this file to `.env` and complete the values.
# `.env` is gitignored: never commit real credentials.

# ============================================================
# Supabase runtime persistence
# ============================================================
# Find both values in Supabase -> Project Settings -> API.
# The service-role key is for this FastAPI backend only. Never expose it in a
# browser, Telegram client, mobile app, or frontend bundle.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-secret>

# Alembic remains the schema source of truth. If it cannot connect through a
# database pooler, generate SQL offline and run it in Supabase SQL Editor:
# `alembic upgrade head --sql`.

# ============================================================
# Scheduler (24/7 paper-trading capture)
# ============================================================
SCHEDULER_ENABLED=false
SCHEDULER_CRON=1 */4 * * *
